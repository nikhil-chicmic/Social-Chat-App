{
  "expo": {
    "name": "SocialHub",
    "slug": "social-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "socialhub",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nikhil.myapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nikhil.myapp",
      "googleServicesFile": "./google-services.json"
    },
    "notification": {
      "icon": "./assets/icon.png"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "7df80275-debd-4a25-bdb4-7334ef6f163f"
      }
    },
    "owner": "nikhil071"
  }
}
